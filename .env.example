# Shared server address. The server uses it as a listen address; the client uses
# it as the remote endpoint.
SERVER_ADDRESS=127.0.0.1:3200

# Server configuration.
DATABASE_DSN=postgres://postgres:password@localhost:5432/gophkeeper?sslmode=disable
# TLS_CERT_FILE=certificates/server.pem
# TLS_KEY_FILE=certificates/server.key
SERVER_INSECURE=true
SESSION_TTL=24h
SHUTDOWN_TIMEOUT=10s
MAX_ENCRYPTED_PAYLOAD_SIZE=15728640
MAX_ENCRYPTED_METADATA_SIZE=66560

# Client configuration.
# TLS_CA_FILE=certificates/ca.pem
# CLIENT_STORAGE_PATH=C:\path\to\gophkeeper.db
# CLIENT_CONFIG_PATH=C:\path\to\config.json
CLIENT_INSECURE=true
